# Server
PORT=3000

# Postgres
POSTGRES_USER=opsagent
POSTGRES_PASSWORD=opsagent
POSTGRES_DB=opsagent
DATABASE_URL=postgresql://opsagent:opsagent@postgres:5432/opsagent

# HubSpot OAuth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/oauth/hubspot/callback
HUBSPOT_SCOPES=crm.objects.contacts.read crm.objects.contacts.write crm.objects.deals.read crm.objects.deals.write

# Must match the webhook "Target URL" registered in the HubSpot app config (webhooks-hsmeta.json).
# HubSpot signs requests against this exact URL, not the raw request path.
HUBSPOT_WEBHOOK_TARGET_URL=

# Token encryption (32-byte key, base64). Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# ChromaDB (RAG policy-doc retrieval)
CHROMA_URL=http://chromadb:8000
CHROMA_POLICY_COLLECTION=opsagent_policies

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
