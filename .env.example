# Server
PORT=3000

# Postgres
POSTGRES_USER=opsagent
POSTGRES_PASSWORD=opsagent
POSTGRES_DB=opsagent
DATABASE_URL=postgresql://opsagent:opsagent@postgres:5432/opsagent

# HubSpot OAuth
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/oauth/hubspot/callback
HUBSPOT_SCOPES=crm.objects.contacts.read crm.objects.contacts.write crm.objects.deals.read crm.objects.deals.write

# Must match the webhook "Target URL" registered in the HubSpot app config (webhooks-hsmeta.json).
# HubSpot signs requests against this exact URL, not the raw request path.
HUBSPOT_WEBHOOK_TARGET_URL=

# Token encryption (32-byte key, base64). Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# ChromaDB (RAG policy-doc retrieval)
CHROMA_URL=http://chromadb:8000
CHROMA_POLICY_COLLECTION=opsagent_policies

# Approval-gate notifier (v2). Only "telegram" is implemented in v2.0.
NOTIFIER=telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Secret token registered via Telegram's setWebhook — echoed back on the
# X-Telegram-Bot-Api-Secret-Token header of every callback request.
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Comma-separated Telegram user IDs allowed to approve/reject plans.
# Non-allowlisted clicks are ignored + audited, never transitioned.
APPROVER_IDS=

# AWAITING_APPROVAL -> EXPIRED after this many hours (SPEC.md §4/§8).
APPROVAL_TIMEOUT_HOURS=24

# Shared secret for n8n's Schedule Trigger to call internal endpoints
# (e.g. the expiry sweep). Generate: openssl rand -hex 32
INTERNAL_API_KEY=
