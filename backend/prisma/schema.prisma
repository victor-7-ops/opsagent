generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id         String   @id @default(uuid())
  hubspotId  String   @unique @map("hubspot_id")
  status     String   @default("received")
  assignedTo String?  @map("assigned_to")
  score      Int?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("leads")
}

model Deal {
  id                String    @id @default(uuid())
  hubspotId         String    @unique @map("hubspot_id")
  stage             String
  lastStageChangeAt DateTime? @map("last_stage_change_at")
  followupSentAt    DateTime? @map("followup_sent_at")

  @@map("deals")
}

model Ticket {
  id             String   @id @default(uuid())
  source         String
  severity       String?
  category       String?
  validityFlag   String?  @map("validity_flag")
  responseDraft  String?  @map("response_draft")
  status         String   @default("received")
  createdAt      DateTime @default(now()) @map("created_at")

  slaAlerts SlaAlert[]

  @@map("tickets")
}

model ActivityLog {
  id        String   @id @default(uuid())
  type      String
  refId     String   @map("ref_id")
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_log")
}

model HubspotToken {
  id                 String   @id @default(uuid())
  accessTokenCipher  String   @map("access_token_cipher")
  refreshTokenCipher String   @map("refresh_token_cipher")
  expiresAt          DateTime @map("expires_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("hubspot_tokens")
}

model SlaAlert {
  id          String    @id @default(uuid())
  ticketId    String    @map("ticket_id")
  breachedAt  DateTime  @map("breached_at")
  notifiedAt  DateTime? @map("notified_at")

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@map("sla_alerts")
}

// --- v2: agentic workflow engine (additive, see SPEC.md §3) ---

model Workflow {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  triggerType       String   @map("trigger_type")
  triggerPayload    Json     @map("trigger_payload")
  state             String   @default("TRIAGED")
  plan              Json?
  planSummary       String?  @map("plan_summary")
  approvedBy        String?  @map("approved_by")
  notifierMessageRef String? @map("notifier_message_ref")
  error             String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  steps WorkflowStep[]

  @@map("workflows")
}

model WorkflowStep {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId     String    @map("workflow_id") @db.Uuid
  stepIndex      Int       @map("step_index")
  tool           String
  args           Json
  idempotencyKey String    @unique @map("idempotency_key")
  status         String    @default("pending")
  result         Json?
  attempts       Int       @default(0)
  executedAt     DateTime? @map("executed_at") @db.Timestamptz(6)

  workflow Workflow @relation(fields: [workflowId], references: [id])

  @@unique([workflowId, stepIndex])
  @@map("workflow_steps")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  workflowId String?  @map("workflow_id") @db.Uuid
  actor      String
  event      String
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("audit_log")
}
